# Supabase (required for recurring homepage feed + dynamic palette)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
NEXT_PUBLIC_GARMENTS_BUCKET=recolor_assets
NEXT_PUBLIC_PREVIEW_BUCKET=recolor_assets
# Optional (if files are inside folder in bucket)
# NEXT_PUBLIC_GARMENTS_PREFIX=assets/garments
# Optional absolute override:
# NEXT_PUBLIC_GARMENTS_BASE_URL=https://your-project.supabase.co/storage/v1/object/public/garments

# Preferred (DeepSeek)
DEEPSEEK_API_KEY=your_deepseek_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# Optional fallback (OpenAI)
OPENAI_API_KEY=your_openai_key_here
OPENAI_MODEL=gpt-4o-mini

NEXT_PUBLIC_APP_URL=https://rangmatch.vercel.app
